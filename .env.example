# Backend
RESEARCHPILOT_APP_NAME=ResearchPilot API
RESEARCHPILOT_DATA_DIR=./data
RESEARCHPILOT_DB_PATH=./data/researchpilot.db
RESEARCHPILOT_REPORTS_DIR=./data/reports
RESEARCHPILOT_CACHE_DIR=./data/cache
RESEARCHPILOT_CHROMA_DIR=./data/chroma
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM
LLM_PROVIDER=openai_compatible
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# OpenAI-compatible providers, for example SenseNova.
# Do not commit real keys. Put the real value only in your local .env.
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=https://token.sensenova.cn/v1
OPENAI_COMPATIBLE_MODEL=sensenova-6.7-flash-lite
LLM_TIMEOUT=45
LLM_TEMPERATURE=0.2
LLM_MAX_RETRIES=2

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
